{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrontStores Admin",
  "version": "1.0.0",
  "identifier": "com.frontstores.admin",
  "build": {
    "frontendDist": "../frontend",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FrontStores Admin",
        "width": 1380,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "../../src-tauri/icons/32x32.png",
      "../../src-tauri/icons/128x128.png",
      "../../src-tauri/icons/128x128@2x.png",
      "../../src-tauri/icons/icon.icns",
      "../../src-tauri/icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "FrontStores Admin Panel",
    "macOS": {
      "signingIdentity": null
    }
  }
}
