{
  "name": "frontstores",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "libs/*",
    "frontend"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "db:migrate": "turbo run db:migrate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "local:prepare-medical": "node tools/local/prepare-local-tenant.mjs",
    "local:sync-prod-metadata": "node tools/local/sync-prod-metadata-to-local.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0",
    "prettier": "^3.2.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
