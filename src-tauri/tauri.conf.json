{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrontStores",
  "version": "1.2.28",
  "identifier": "com.frontstores.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FrontStores",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://update.frontstores.com http://localhost:11434 http://192.168.*:7788; script-src 'self' 'unsafe-inline' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; media-src 'self' blob:; font-src 'self' data:"
    }
  },
  "plugins": {
    "shell": {
      "open": "(mailto:.+)|(tel:.+)|(https?://.+)|(/[^-].+)"
    },
    "updater": {
      "active": true,
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0RDk2QTE5NEY4MjYwMTAKUldRUVlJSlBHV3JaOUVrOCtvcmRWSDRzM3pwL0FFcGFsc1djNDZ5K3N1a2Q2eS85MnVtTXN5b2IK",
      "endpoints": [
        "https://github.com/imrakeshsoni/frontstores/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Offline-first shop management for Indian businesses",
    "macOS": {
      "signingIdentity": null,
      "entitlements": "./entitlements.plist",
      "infoPlist": "./Info.plist"
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}