{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrontStores",
  "version": "1.0.8",
  "identifier": "com.frontstores.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FrontStores",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0RDk2QTE5NEY4MjYwMTAKUldRUVlJSlBHV3JaOUVrOCtvcmRWSDRzM3pwL0FFcGFsc1djNDZ5K3N1a2Q2eS85MnVtTXN5b2IK",
      "endpoints": [
        "https://github.com/imrakeshsoni/frontstores/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Offline-first shop management for Indian businesses",
    "macOS": {
      "signingIdentity": null
    }
  }
}